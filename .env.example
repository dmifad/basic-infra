# ============================================================================
# basic-infra — environment template
# Copy to .env.local and edit. .env.local is gitignored.
# ============================================================================

# ─── Gateway service ────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0                 # bind inside the container
GATEWAY_PORT=8003                    # listen port inside the container
GATEWAY_HOST_PORT=8003               # host port published on 127.0.0.1
                                     # (override if 8003 is taken — e.g. 8013)
GATEWAY_LOG_LEVEL=INFO
GATEWAY_LOG_FORMAT=json              # json|console

# ─── Tenant store ───────────────────────────────────────────────────────────
TENANT_DB_PATH=/data/tenants/tenants.db
GATEWAY_UID=1000                     # run the gateway container as this uid:gid
GATEWAY_GID=1000                     # so the bind-mounted tenant DB is host-writable

# ─── Rate limiting ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_FAIL_OPEN=true            # accept requests when redis is unreachable

# ─── Backend registry ───────────────────────────────────────────────────────
BACKENDS_CONFIG=/app/backends.yaml
BACKEND_HEALTH_INTERVAL_SECONDS=30
BACKEND_UNHEALTHY_THRESHOLD=3
BACKEND_REQUEST_TIMEOUT_SECONDS=900

# ─── Models on the host ─────────────────────────────────────────────────────
LLM_MODELS_DIR=/home/vams/llm-models

# ─── llama.cpp T-pro tuning ─────────────────────────────────────────────────
TPRO_CPU_THREADS=8
LLM_CTX_SIZE_CPU=8192
LLM_CTX_SIZE_GPU=4096
LLAMA_GPU_DEVICES=0
LLAMA_N_GPU_LAYERS=24

# ─── Storage layer (Week 6) ─────────────────────────────────────────────────
BASIC_INFRA_STORAGE_BACKEND=minio
BASIC_INFRA_STORAGE_BUCKET=basic-infra-dev
BASIC_INFRA_STORAGE_ENDPOINT_URL=http://minio:9000
BASIC_INFRA_STORAGE_ACCESS_KEY=minioadmin
BASIC_INFRA_STORAGE_SECRET_KEY=minioadmin

# ─── Observability (Week 7; canonical ports reclaimed Week 11) ──────────────
# All bind to 127.0.0.1. The Week-11 cutover reclaimed the canonical host ports
# from telcoss's (now decommissioned) own observability stack.
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
ENV=dev                              # compose-level env: drives container labels (${ENV})
# SDK config (read by services that adopt basic_infra_observability_client):
BASIC_INFRA_OBSERVABILITY_SERVICE_NAME=basic-infra
BASIC_INFRA_OBSERVABILITY_ENV=dev
BASIC_INFRA_OBSERVABILITY_LOG_FORMAT=json
BASIC_INFRA_OBSERVABILITY_TENANT=telcoss    # consumer name; also drives outbox-dispatcher labels

# ── postgres-multi (ADR-0013) ──────────────────────────────────────────────
# Control plane (admin / provisioning). Используется postgres.LocalAdapter
# и Makefile-таргетами provision/deprovision. Client projects этих кред НЕ
# имеют — у них только BASIC_INFRA_POSTGRES_* (см. ниже).
POSTGRES_MULTI_PORT=5434                  # cutover-нейтрально; telcoss держит 5433
POSTGRES_MULTI_ADMIN_USER=postgres
POSTGRES_MULTI_ADMIN_PASSWORD=changeme-please

# Data plane (SDK basic_infra_postgres_client). Это пример для client project;
# реальные значения живут в .env самого проекта, не здесь.
BASIC_INFRA_POSTGRES_TENANT=telcoss
BASIC_INFRA_POSTGRES_ENV=dev              # SDK-specific; compose-сторона читает ENV
BASIC_INFRA_POSTGRES_PROVIDER=local       # local | managed
BASIC_INFRA_POSTGRES_HOST=localhost
BASIC_INFRA_POSTGRES_PORT=5434
BASIC_INFRA_POSTGRES_USER=postgres
BASIC_INFRA_POSTGRES_PASSWORD=changeme-please

# ─── Client SDK (for clients) ───────────────────────────────────────────────
# These go into telcoss/.env or pamyat-naroda/.env, not basic-infra's.
# LLM_PROVIDER=basic-infra            # basic-infra|openai|anthropic
# LLM_BASE_URL=http://localhost:8003/v1
# LLM_API_KEY=tnk_live_<from "basic-infra tenant create" output>
# LLM_CACHE_DIR=                      # set to enable embedding cache, e.g. ~/.cache/vams-llm

# Week 9 redis-shared control-plane admin (set the real password in .env + redis_shared/acl/users.acl)
BASIC_INFRA_REDIS_ADMIN_USERNAME=admin
BASIC_INFRA_REDIS_ADMIN_PASSWORD=changeme-strong-admin-password

# ─── Outbox dispatcher (ADR-0019; --profile outbox) ─────────────────────────
# All four vars are REQUIRED — no defaults in the engine (K1-b, ADR-0020).
# Consumer supplies the contract values; operator B substitutes their own.
OUTBOX_READER_PASSWORD=changeme-outbox-reader-password
OUTBOX_DSN=postgresql://outbox_reader:<password>@postgres-multi:5432/<tenant-db>
OUTBOX_TABLE=inventory.outbox          # schema-qualified; telcoss uses inventory.outbox
OUTBOX_CHANNEL=telcoss_outbox          # NOTIFY channel; telcoss uses telcoss_outbox

# ─── Authentik (ADR-0018; --profile authentik) ──────────────────────────────
AUTHENTIK_SECRET_KEY=changeme-generate-with-openssl-rand-base64-36
AUTHENTIK_PG_PASSWORD=changeme-strong-pg-password
AUTHENTIK_BOOTSTRAP_PASSWORD=changeme-akadmin-password
# AUTHENTIK_BOOTSTRAP_EMAIL defaults to admin@platform.local; override if needed.
