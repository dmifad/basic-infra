# ============================================================================
# basic-infra — environment template
# Copy to .env.local and edit. .env.local is gitignored.
# ============================================================================

# ─── Gateway service ────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0                 # bind inside the container
GATEWAY_PORT=8003                    # listen port inside the container
GATEWAY_HOST_PORT=8003               # host port published on 127.0.0.1
                                     # (override if 8003 is taken — e.g. 8013)
GATEWAY_LOG_LEVEL=INFO
GATEWAY_LOG_FORMAT=json              # json|console

# ─── Tenant store ───────────────────────────────────────────────────────────
TENANT_DB_PATH=/data/tenants/tenants.db
GATEWAY_UID=1000                     # run the gateway container as this uid:gid
GATEWAY_GID=1000                     # so the bind-mounted tenant DB is host-writable

# ─── Rate limiting ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_FAIL_OPEN=true            # accept requests when redis is unreachable

# ─── Backend registry ───────────────────────────────────────────────────────
BACKENDS_CONFIG=/app/backends.yaml
BACKEND_HEALTH_INTERVAL_SECONDS=30
BACKEND_UNHEALTHY_THRESHOLD=3
BACKEND_REQUEST_TIMEOUT_SECONDS=900

# ─── Models on the host ─────────────────────────────────────────────────────
LLM_MODELS_DIR=/home/vams/llm-models

# ─── llama.cpp T-pro tuning ─────────────────────────────────────────────────
TPRO_CPU_THREADS=8
LLM_CTX_SIZE_CPU=8192
LLM_CTX_SIZE_GPU=4096
LLAMA_GPU_DEVICES=0
LLAMA_N_GPU_LAYERS=24

# ─── Storage layer (Week 6) ─────────────────────────────────────────────────
BASIC_INFRA_STORAGE_BACKEND=minio
BASIC_INFRA_STORAGE_BUCKET=basic-infra-dev
BASIC_INFRA_STORAGE_ENDPOINT_URL=http://minio:9000
BASIC_INFRA_STORAGE_ACCESS_KEY=minioadmin
BASIC_INFRA_STORAGE_SECRET_KEY=minioadmin

# ─── Observability (Week 7) ─────────────────────────────────────────────────
# Host ports are offset during the telcoss transition (ADR-0011 §7); all bind
# to 127.0.0.1. Cutover (Week 11) returns them to 9090/3100/3000.
PROMETHEUS_PORT=9190
LOKI_PORT=3110
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
ENV=dev                              # compose-level env: drives container labels (${ENV})
# SDK config (read by services that adopt basic_infra_observability_client):
BASIC_INFRA_OBSERVABILITY_SERVICE_NAME=basic-infra
BASIC_INFRA_OBSERVABILITY_ENV=dev
BASIC_INFRA_OBSERVABILITY_LOG_FORMAT=json

# ─── Client SDK (for clients) ───────────────────────────────────────────────
# These go into telcoss/.env or pamyat-naroda/.env, not basic-infra's.
# LLM_PROVIDER=basic-infra            # basic-infra|openai|anthropic
# LLM_BASE_URL=http://localhost:8003/v1
# LLM_API_KEY=tnk_live_<from "basic-infra tenant create" output>
# LLM_CACHE_DIR=                      # set to enable embedding cache, e.g. ~/.cache/vams-llm
